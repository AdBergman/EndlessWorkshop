{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "framer-motion": "^12.40.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-csv": "^2.2.2",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "react-toastify": "^11.1.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "scripts": {
    "start": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "lint": "eslint .",
    "test": "vitest --config vitest.config.ts",
    "diagnostics:codex-content": "node --experimental-strip-types scripts/codex-content-quality-diagnostic.ts",
    "diagnostics:codex-preview-surfaces": "node --experimental-strip-types scripts/codex-preview-surface-audit.ts",
    "diagnostics:codex-relationship-gaps": "node --experimental-strip-types scripts/codex-relationship-value-gap-audit.ts",
    "diagnostics:quests": "vite-node --config vite.config.ts scripts/quest-explorer-diagnostic.ts",
    "diagnostics:quests:lore-chronology": "vite-node --config vite.config.ts scripts/quest-lore-chronology-diagnostic.ts"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-csv": "^1.1.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
